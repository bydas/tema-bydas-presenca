{{ 'component-download-material-modal.css' | asset_url | stylesheet_tag }}

<style>
  #downloadCodeModal .custom-confirm-cancel {
    background-color: {{ settings.pre_venda_cancel_bg | default: '#e5e7eb' }};
    color: {{ settings.pre_venda_cancel_text_color | default: '#1f2937' }};
  }

  #downloadCodeModal .custom-confirm-cancel:hover {
    background-color: {{ settings.pre_venda_cancel_bg_hover | default: '#d1d5db' }};
  }

  #downloadCodeModal .custom-confirm-content {
    background: {{ settings.pre_venda_bg_color | default: '#ffffff' }};
  }

  #downloadCodeModal .custom-confirm-message {
    color: {{ settings.pre_venda_message_color | default: '#1f2937' }};
  }

  #downloadCodeModal .custom-confirm-ok {
    background-color: {{ settings.pre_venda_ok_bg | default: '#2563eb' }};
    color: {{ settings.pre_venda_ok_text_color | default: '#ffffff' }};
  }

  #downloadCodeModal .custom-confirm-ok:hover {
    background-color: {{ settings.pre_venda_ok_bg_hover | default: '#1d4ed8' }};
  }

  body.modal-open {
    overflow: hidden;
    position: fixed;
    width: 100%;
    height: 100%;
  }
</style>

<div id="downloadCodeModal">
  <div class="custom-confirm-content">
    <div class="custom-confirm-message" id="downloadCodeMessage">Insira o código para aceder ao material bónus:</div>

    <input
      type="text"
      id="downloadCodeInput"
      placeholder="Código"
      autocomplete="off"
    >

    <div id="downloadCodeError"></div>

    <div class="custom-confirm-buttons">
      <button id="downloadCodeOk" class="custom-confirm-ok">OK</button>
      <button id="downloadCodeCancel" class="custom-confirm-cancel">Cancelar</button>
    </div>
  </div>
</div>

<script>
  (function() {
    const productId = {{ product.id | json }};
    const url = 'https://presenca.apps.bydas.com/';
    let isProcessing = false;

    function lockScroll() {
      document.body.classList.add('modal-open');
    }

    function unlockScroll() {
      document.body.classList.remove('modal-open');
    }

    function redirectToMaterial(materialUrl) {
      if (!materialUrl) return;
      window.location.href = materialUrl;
    }

    async function validateAndRedirect(okBtn, input, errorDiv, closeModal) {
      if (isProcessing) return;

      const enteredCode = input.value.trim();

      if (!enteredCode) {
        errorDiv.textContent = 'Digite um código.';
        errorDiv.style.display = 'block';
        return;
      }

      isProcessing = true;

      const originalText = okBtn.textContent;
      okBtn.disabled = true;
      okBtn.textContent = 'A validar...';

      try {
        const response = await fetch(
          `${url}?action=validate_download&product_id=${encodeURIComponent(productId)}&code=${encodeURIComponent(enteredCode)}`
        );

        const data = await response.json();

        if (response.ok && data.success && data.url) {
          closeModal();
          redirectToMaterial(data.url);
        } else {
          const msg = data.error || 'Código incorreto. Verifique e tente novamente.';
          errorDiv.textContent = msg;
          errorDiv.style.display = 'block';
          input.value = '';
          input.focus();
        }
      } catch (err) {
        errorDiv.textContent = 'Erro ao conectar com o servidor. Tente novamente.';
        errorDiv.style.display = 'block';
      } finally {
        isProcessing = false;
        okBtn.disabled = false;
        okBtn.textContent = originalText;
      }
    }

    function promptForCode() {
      const modal = document.getElementById('downloadCodeModal');
      if (!modal) return;

      const input = document.getElementById('downloadCodeInput');
      const errorDiv = document.getElementById('downloadCodeError');
      const okBtn = document.getElementById('downloadCodeOk');
      const cancelBtn = document.getElementById('downloadCodeCancel');

      input.value = '';
      errorDiv.textContent = '';
      errorDiv.style.display = 'none';

      modal.style.display = 'flex';
      lockScroll();

      setTimeout(() => {
        input.focus();
      }, 50);

      const closeModal = () => {
        modal.style.display = 'none';
        unlockScroll();
        isProcessing = false;
      };

      const newOkBtn = okBtn.cloneNode(true);
      const newCancelBtn = cancelBtn.cloneNode(true);

      okBtn.parentNode.replaceChild(newOkBtn, okBtn);
      cancelBtn.parentNode.replaceChild(newCancelBtn, cancelBtn);

      const finalOkBtn = document.getElementById('downloadCodeOk');
      const finalCancelBtn = document.getElementById('downloadCodeCancel');

      finalOkBtn.onclick = () => {
        validateAndRedirect(finalOkBtn, input, errorDiv, closeModal);
      };

      finalCancelBtn.onclick = closeModal;

      modal.onclick = (e) => {
        if (e.target === modal) closeModal();
      };

      input.onkeypress = (e) => {
        if (e.key === 'Enter') {
          validateAndRedirect(finalOkBtn, input, errorDiv, closeModal);
        }
      };
    }

    const downloadButton = document.querySelector('.download_material_content');

    if (downloadButton) {
      downloadButton.addEventListener('click', function(event) {
        event.preventDefault();
        promptForCode();
      });
    }
  })();
</script>
