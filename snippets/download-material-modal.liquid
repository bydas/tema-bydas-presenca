{{ 'component-download-material-modal.css' | asset_url | stylesheet_tag }}

<div
  id="downloadCodeModal"
  style="display: none; position: fixed; top:0; left:0; width:100%; height:100%; background-color: rgba(0,0,0,0.5); justify-content: center; align-items: center; z-index: 10000;"
>
  <div
    class="custom-confirm-content"
    style="padding: 1.5rem; border-radius: 12px; max-width: 400px; width: 90%; box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1); text-align: center; background: #ffffff;"
  >
    <div
      class="custom-confirm-message"
      id="downloadCodeMessage"
      style="font-size: 1.35rem; margin-bottom: 1rem; line-height: 1.5; color: #1f2937;"
    >
      Digite o código de acesso para baixar o material:
    </div>
    <input
      type="text"
      id="downloadCodeInput"
      style="width: 80%; padding: 10px; margin-bottom: 1.5rem; border: 1px solid #ccc; border-radius: 6px; font-size: 1rem; text-align: center;"
      placeholder="Código"
      autocomplete="off"
    >
    <div id="downloadCodeError" style="color: #dc2626; font-size: 0.875rem; margin-bottom: 1rem; display: none;"></div>
    <div class="custom-confirm-buttons" style="display: flex; gap: 12px; justify-content: center;">
      <button
        id="downloadCodeOk"
        class="custom-confirm-ok"
        style="background-color: #2563eb; color: white; padding: 8px 20px; border: none; border-radius: 6px; font-size: 1.25rem; font-weight: 500; cursor: pointer;"
      >
        OK
      </button>
      <button
        id="downloadCodeCancel"
        class="custom-confirm-cancel"
        style="background-color: #e5e7eb; color: #1f2937; padding: 8px 20px; border: none; border-radius: 6px; font-size: 1.25rem; font-weight: 500; cursor: pointer;"
      >
        Cancelar
      </button>
    </div>
  </div>
</div>
