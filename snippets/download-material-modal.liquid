{{ 'component-download-material-modal.css' | asset_url | stylesheet_tag }}

<style>
  #downloadCodeModal .custom-confirm-cancel {
    background-color: {{ settings.pre_venda_cancel_bg | default: '#e5e7eb' }};
    color: {{ settings.pre_venda_cancel_text_color | default: '#1f2937' }};
  }

  #downloadCodeModal .custom-confirm-cancel:hover {
    background-color: {{ settings.pre_venda_cancel_bg_hover | default: '#d1d5db' }};
  }

  #downloadCodeModal .custom-confirm-content {
    background: {{ settings.pre_venda_bg_color | default: '#ffffff' }};
  }

  #downloadCodeModal .custom-confirm-message {
    color: {{ settings.pre_venda_message_color | default: '#1f2937' }};
  }

  #downloadCodeModal .custom-confirm-ok {
    background-color: {{ settings.pre_venda_ok_bg | default: '#2563eb' }};
    color: {{ settings.pre_venda_ok_text_color | default: '#ffffff' }};
  }

  #downloadCodeModal .custom-confirm-ok:hover {
    background-color: {{ settings.pre_venda_ok_bg_hover | default: '#1d4ed8' }};
  }

  .popup-info-message {
    background-color: #fef3c7;
    border: 1px solid #fbbf24;
    border-radius: 8px;
    padding: 10px;
    margin-bottom: 1rem;
    font-size: 0.875rem;
    color: #92400e;
    display: none;
    text-align: left;
  }

  .popup-info-message a {
    color: #2563eb;
    text-decoration: underline;
    cursor: pointer;
  }

  .popup-info-message.show {
    display: block;
  }
</style>

<div id="downloadCodeModal">
  <div class="custom-confirm-content">
    <div class="custom-confirm-message" id="downloadCodeMessage">Digite o código de acesso para baixar o material:</div>

    <div class="popup-info-message" id="popupInfoMessage">
      <strong>Pop-up bloqueado!</strong><br>
      O navegador bloqueou a abertura dos downloads. Clique em
      <a href="#" id="forceDownloadLink">baixar agora</a> ou permita pop-ups para este site.
    </div>

    <input
      type="text"
      id="downloadCodeInput"
      placeholder="Código"
      autocomplete="off"
    >
    <div id="downloadCodeError"></div>
    <div class="custom-confirm-buttons">
      <button id="downloadCodeOk" class="custom-confirm-ok">OK</button>
      <button id="downloadCodeCancel" class="custom-confirm-cancel">Cancelar</button>
    </div>
  </div>
</div>

<script>
  (function() {
    const productId = {{ product.id }};
    const url = 'https://presenca.apps.bydas.com/';
    let pendingUrls = [];

    function downloadFiles(urls) {
      if (!urls || urls.length === 0) return;
      
      pendingUrls = urls;
      let downloadStarted = false;
      
      urls.forEach((fileUrl, index) => {
        const link = document.createElement('a');
        link.href = fileUrl;
        link.download = '';
        link.target = '_blank';
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        downloadStarted = true;
        if (index < urls.length - 1) setTimeout(() => {}, 300);
      });
      
      if (downloadStarted) {
        setTimeout(() => {
          const popupMessage = document.getElementById('popupInfoMessage');
          if (popupMessage && !popupMessage.classList.contains('show')) {
            popupMessage.classList.add('show');
          }
        }, 1000);
      }
    }

    function forceDownload() {
      if (pendingUrls.length === 0) return;
      
      pendingUrls.forEach((fileUrl, index) => {
        const link = document.createElement('a');
        link.href = fileUrl;
        link.download = '';
        link.target = '_self';
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        if (index < pendingUrls.length - 1) setTimeout(() => {}, 300);
      });
      
      const popupMessage = document.getElementById('popupInfoMessage');
      if (popupMessage) {
        popupMessage.classList.remove('show');
      }
    }

    function promptForCode() {
      const modal = document.getElementById('downloadCodeModal');
      if (!modal) return;

      const input = document.getElementById('downloadCodeInput');
      const errorDiv = document.getElementById('downloadCodeError');
      const okBtn = document.getElementById('downloadCodeOk');
      const cancelBtn = document.getElementById('downloadCodeCancel');
      const messageDiv = document.getElementById('downloadCodeMessage');
      const popupMessage = document.getElementById('popupInfoMessage');
      const forceLink = document.getElementById('forceDownloadLink');

      if (popupMessage) popupMessage.classList.remove('show');
      input.value = '';
      errorDiv.style.display = 'none';
      messageDiv.textContent = 'Digite o código de acesso para baixar o material:';
      modal.style.display = 'flex';
      input.focus();

      const closeModal = () => {
        modal.style.display = 'none';
        pendingUrls = [];
      };

      const validateAndDownload = async () => {
        const enteredCode = input.value.trim();
        if (!enteredCode) {
          errorDiv.textContent = 'Digite um código.';
          errorDiv.style.display = 'block';
          return;
        }

        okBtn.disabled = true;
        okBtn.textContent = 'Validando...';

        try {
          const response = await fetch(`${url}?action=validate_download&product_id=${productId}&code=${encodeURIComponent(enteredCode)}`);
          const data = await response.json();

          if (response.ok && data.success) {
            closeModal();
            downloadFiles(data.urls);
          } else {
            const msg = data.error || 'Código incorreto. Verifique e tente novamente.';
            errorDiv.textContent = msg;
            errorDiv.style.display = 'block';
            input.value = '';
            input.focus();
          }
        } catch (err) {
          errorDiv.textContent = 'Erro ao conectar com o servidor. Tente novamente.';
          errorDiv.style.display = 'block';
        } finally {
          okBtn.disabled = false;
          okBtn.textContent = 'OK';
        }
      };

      if (forceLink) {
        forceLink.onclick = (e) => {
          e.preventDefault();
          forceDownload();
        };
      }

      const newOk = okBtn.cloneNode(true);
      const newCancel = cancelBtn.cloneNode(true);
      okBtn.parentNode.replaceChild(newOk, okBtn);
      cancelBtn.parentNode.replaceChild(newCancel, cancelBtn);

      document.getElementById('downloadCodeOk').onclick = validateAndDownload;
      document.getElementById('downloadCodeCancel').onclick = closeModal;

      modal.onclick = (e) => {
        if (e.target === modal) closeModal();
      };

      input.onkeypress = (e) => {
        if (e.key === 'Enter') validateAndDownload();
      };
    }

    const downloadButton = document.querySelector('.download_material_content');
    if (downloadButton) {
      downloadButton.addEventListener('click', function(event) {
        event.preventDefault();
        promptForCode();
      });
    }
  })();
</script>
